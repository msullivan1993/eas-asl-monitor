# ============================================================
#  EAS/SAME AllStarLink Monitor — Configuration File
#  /etc/eas_monitor/fips_nodes.conf
#
#  Generated by setup_wizard.py — edit carefully.
#  File permissions should be 600 (owner read/write only).
#  This file may contain stream credentials.
# ============================================================


[settings]
# Your AllStarLink node number (public, registered node)
local_node = 12345

# Your public node (usually same as local_node for single-node installs)
public_node = 12345

# Audio source: usb_shared | usb_direct | rtlsdr | stream
audio_source = usb_shared

# Log file path
log_file = /var/log/eas_monitor.log

# Hard cap on link duration in seconds (safety net — purge time + 30s used normally)
max_link_duration = 3600

# Event type filtering
act_on_warnings = true     # TOR, SVR, FFW, etc. — recommended: true
act_on_watches  = false    # TOA, SVA, FFA, etc. — your preference
act_on_tests    = false    # RMT, RWT, NPT — false in production


# ── Asterisk AMI ──────────────────────────────────────────────────────────────
# Credentials from /etc/asterisk/manager.conf
[ami]
host = 127.0.0.1
port = 5038
user = eas_monitor
pass = CHANGEME


# ── USB Shared Source ─────────────────────────────────────────────────────────
# Used when audio_source = usb_shared
# ALSA dsnoop tap on existing RIM-Lite or node audio device
[source_usb_shared]
device      = eas_tap   # ALSA dsnoop device (created by installer)
sample_rate = 22050


# ── USB Direct Source ─────────────────────────────────────────────────────────
# Used when audio_source = usb_direct
# Dedicated weather radio + USB audio dongle
[source_usb_direct]
device      = hw:1,0    # Run 'arecord -l' to find your device
sample_rate = 22050


# ── RTL-SDR Source ────────────────────────────────────────────────────────────
# Used when audio_source = rtlsdr
[source_rtlsdr]
# Comma-separated NOAA WX frequencies in Hz
# One frequency = single mode (rtl_fm, ~5% CPU)
# Multiple = wideband mode (numpy demod, requires more CPU)
# All 7 for Pi 4: 162400000, 162425000, 162450000, 162475000, 162500000, 162525000, 162550000
frequencies    = 162550000

device_index   = 0      # RTL-SDR device index (0 = first dongle)
gain           = 40     # Tuner gain (0 = auto, try 20-50)
ppm_correction = 0      # PPM offset (run 'rtl_test -t' to calibrate)


# ── Stream Source ─────────────────────────────────────────────────────────────
# Used when audio_source = stream
[source_stream]

# Option A — Plain URL (noaaweatherradio.org, weatherusa.net)
url = http://your.stream/mount

# Option B — Broadcastify premium (comment out 'url' above)
# Feed ID is the number from: broadcastify.com/listen/feed/FEEDID
;broadcastify_feed_id = 34002
;broadcastify_username = your_radioreference_username
;broadcastify_password = your_radioreference_password

sample_rate      = 22050
reconnect_delay  = 30


# ── USRP Private Nodes ────────────────────────────────────────────────────────
# Required for: usb_direct, rtlsdr, stream
# NOT needed for: usb_shared (existing node carries audio)
# Format: node_key = tx_port:rx_port
# tx_port = port app_rpt (chan_usrp) listens on
# rx_port = port EAS monitor listens on
[usrp_nodes]
;default = 34001:32001          # Single USRP node
;162550000 = 34001:32001        # RTL-SDR multi: one per frequency
;162400000 = 34003:32003


# ── Alert Behavior ────────────────────────────────────────────────────────────
# How each event type connects to nodes:
#   propagate = ilink 3 — audio reaches destination node's entire linked network
#   local     = ilink 8 — audio heard on your node only, not propagated
#   skip      = do not connect any nodes for this event type
[alert_behavior]
TOR = propagate    # Tornado Warning
SVR = propagate    # Severe Thunderstorm Warning
FFW = propagate    # Flash Flood Warning
EWW = propagate    # Extreme Wind Warning
HUW = propagate    # Hurricane Warning
SMW = propagate    # Special Marine Warning
SQW = propagate    # Snow Squall Warning
DSW = propagate    # Dust Storm Warning
BZW = propagate    # Blizzard Warning
WSW = propagate    # Winter Storm Warning
CEM = propagate    # Civil Emergency Message
EAN = propagate    # Presidential Alert — always propagate
TOA = local        # Tornado Watch
SVA = local        # Severe Thunderstorm Watch
FFA = local        # Flash Flood Watch
RMT = skip         # Monthly Test — skip in production
RWT = skip         # Weekly Test — skip in production


# ── Recording ─────────────────────────────────────────────────────────────────
[recording]
enabled        = true
directory      = /var/lib/eas_monitor/recordings
max_recordings = 5
# DTMF playback: *91 = most recent, *92 = second most recent, etc.
# (Configured in /etc/asterisk/rpt.conf [functions] by installer)


# ── FIPS Code → ASL Node Mapping ─────────────────────────────────────────────
# Format: FIPS_code = node_number   [# optional comment]
#
# FIPS codes: SSSCCC
#   SSS = 3-digit state code  (e.g. 021 = Kentucky, 039 = Ohio)
#   CCC = 3-digit county code (e.g. 019 = Boyd County)
#
# State wildcard: SSS000 matches all counties in that state
#   e.g. 039000 = all of Ohio
#
# Find codes: https://www.weather.gov/pimar/PubZoneFIPS
# Find transmitter coverage: https://www.nws.noaa.gov/nwr/stations.htm
[fips_map]

# ── Example: Boyd County, KY area ─────────────────────────────────────────────
;021019 = 54321   # Boyd County, KY
;021089 = 54321   # Greenup County, KY
;021043 = 54321   # Carter County, KY
;054011 = 54321   # Cabell County, WV
;054099 = 54321   # Wayne County, WV

# ── Example: Ohio (statewide) ─────────────────────────────────────────────────
;039000 = 67890   # All of Ohio → connect node 67890


# ── National/Presidential Alert Node Override ─────────────────────────────────
# These events connect regardless of FIPS codes.
# Useful for routing presidential alerts to a dedicated net node.
[event_node_override]
;EAN = 99999   # Presidential alert → national net node
